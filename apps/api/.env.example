# Database Configuration (Production)
DB_HOST=your_database_host
DB_PORT=1433
DB_USERNAME=your_db_username
DB_PASSWORD=your_db_password
DB_DATABASE=account_manager
DB_ENCRYPT=false
DB_TRUST_CERT=true

DB_MIGRATION_HOST=your_database_host
DB_MIGRATION_PORT=1433
DB_MIGRATION_USERNAME=your_db_username
DB_MIGRATION_PASSWORD=your_db_password
DB_MIGRATION_DATABASE=account_manager



# JWT Configuration
JWT_SECRET=your_super_secret_jwt_key_at_least_32_characters_long
JWT_EXPIRES_IN=24h

# Hashed vs Plain
FEATURE_HASHED=false

# App Builder Feature
FEATURE_APP_BUILDER=false

# CORS Configuration
CORS_ORIGINS=http://localhost:5173,http://localhost:3000,http://60.248.245.252:8080,https://acm.twsbp.com,http://acm-api.twsbp.com
CORS_CREDENTIALS=true

# Document Upload Feature
FEATURE_DOC_UPLOAD=false

# Document Kinds Management Feature
FEATURE_DOC_KINDS_MANAGEMENT=false

# File Upload Configuration
UPLOAD_MAX_FILE_SIZE=104857600
UPLOAD_DEST_DIR=./uploads/documents

# API External Access Configuration
# Protocol (http/https) for external callbacks to this API from OnlyOffice Document Server
API_PROTOCOL=http
# Host/hostname for external callbacks to this API (must be reachable from OnlyOffice Document Server)
# Examples:
#   - For Docker Desktop: host.docker.internal:3000
#   - For LAN access: 192.168.0.10:3000
#   - For public access: api.yourdomain.com:3000
API_HOST=localhost:3000

# Document Server Feature
FEATURE_DOC_SERVER=false

# OnlyOffice Document Server
ONLYOFFICE_DOCUMENT_SERVER_URL=http://localhost:8081
ONLYOFFICE_JWT_SECRET=your_onlyoffice_jwt_secret_at_least_32_characters_long

# Document permissions
# Roles:
#   admin   - full control (create, edit, delete)
#   manager - same as admin
#   user    - view-only
# documentAccessLevel is reserved for future use; current release ignores it.

# Jenkins Configuration (External Server)
# Jenkins server URL - external access from API
JENKINS_URL=http://60.248.245.252:8080
# Jenkins username (your service account)
JENKINS_USERNAME=your_jenkins_username
# Jenkins API token (recommended) or password
# Get from: Jenkins → Your Username → Configure → API Token → Add New Token
JENKINS_PASSWORD=your_jenkins_api_token
# Jenkins job name that will execute Android build pipeline
JENKINS_JOB_NAME=tc-app
# Default git branch to pass to Jenkins (must match Jenkinsfile parameters)
JENKINS_GIT_BRANCH=ci
# Company identifier to scope artifacts in MinIO (matches Jenkinsfile parameter)
JENKINS_COMPANY=TWSBP

# MinIO Configuration (Jenkins and MinIO on same server, API accesses externally)
# MinIO server endpoint - external access from API
MINIO_ENDPOINT=60.248.245.252:9000
# MinIO access credentials (change defaults for production)
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin123
# Bucket name for storing Android APK artifacts
MINIO_ANDROID_ARTIFACTS_BUCKET=android-builds
# Bucket name for storing Google Services files
MINIO_GOOGLE_SERVICES_BUCKET=google-services
# Bucket name for storing document files
MINIO_DOCUMENTS_BUCKET=account-manager-documents

