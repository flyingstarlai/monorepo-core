# Database Configuration (Production)
DB_HOST=your_database_host
DB_PORT=1433
DB_USERNAME=your_db_username
DB_PASSWORD=your_db_password
DB_DATABASE=account_manager

# JWT Configuration
JWT_SECRET=your_super_secret_jwt_key_at_least_32_characters_long
JWT_EXPIRES_IN=24h

# Hashed vs Plain
FEATURE_HASHED=false

# CORS Configuration
CORS_ORIGINS=http://localhost:5173,http://localhost:3000,http://acm.twsbp.com,https://acm.twsbp.com,http://acm-api.twsbp.com,https://acm-api.twsbp.com
CORS_CREDENTIALS=true