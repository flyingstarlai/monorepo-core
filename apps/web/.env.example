# Frontend Environment Configuration
# Copy this file to .env and update with your actual values

# API Configuration
# API base URL for the application
# This is the only API URL used - set it to your company's API endpoint
VITE_BASE_PUBLIC=https://ls-acm-api.twsbp.net

# Company Configuration
# Company name displayed in the application
VITE_COMPANY_NAME=Comp Inc

# Development Tools
# Enable/disable React and Router devtools (set to 'false' to disable)
# VITE_ENABLE_DEVTOOLS=true

# Optional: Feature flags
# VITE_ENABLE_ANALYTICS=false
# VITE_ENABLE_DEBUG=true
# VITE_FEATURE_APP_BUILDER=false
# VITE_FEATURE_DOC_UPLOAD=false
# VITE_FEATURE_DOC_SERVER=false

# Optional: External services
# VITE_SENTRY_DSN=your_sentry_dsn
# VITE_GOOGLE_ANALYTICS_ID=your_ga_id