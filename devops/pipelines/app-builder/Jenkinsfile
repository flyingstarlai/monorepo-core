pipeline {
    agent any

    parameters {
        string(name: 'APP_NAME', defaultValue: '合併生產', description: 'Application display name (supports Traditional Chinese)')
        string(name: 'APP_ID', defaultValue: 'com.twsbp.TCS01', description: 'Application package identifier (e.g., com.twsbp.XXXX)')
        string(name: 'SERVER_IP', defaultValue: '60.248.245.253', description: 'Server IP address')
        string(name: 'APP_MODULE', defaultValue: '001', description: 'Application module identifier')
        string(name: 'MINIO_BUCKET', defaultValue: 'android-builds', description: 'MinIO bucket for artifact storage')
        string(name: 'GIT_BRANCH', defaultValue: 'ci', description: 'Git branch to build from https://github.com/twsbp/tc-app-kotlin.git')
        string(name: 'COMPANY', defaultValue: 'TWSBP', description: 'Company identifier for MinIO bucket organization')
        string(name: 'BUILD_ID', defaultValue: '', description: 'Build ID from API for webhook callback')
    }

    environment {
        // Initialize pipeline start time at the very beginning
        PIPELINE_START_TIME = "${System.currentTimeMillis()}"

        // Custom Android builder image built from ci/docker/android-builder.Dockerfile
        DOCKER_IMAGE_TAG = 'twsbpmac/ci-android:api36-jdk17'
        MINIO_ENDPOINT = 'http://minio:9000'
        MINIO_ACCESS_KEY = 'minioadmin'
        MINIO_SECRET_KEY = 'minioadmin123'
        GIT_REPO_URL = 'https://github.com/twsbp/tc-app-kotlin.git'
        GIT_CREDENTIALS_ID = 'github-token'
        API_ENDPOINT = 'http://acm-api:3000/api/v1/app-builder'
    }

    options {
        buildDiscarder(logRotator(numToKeepStr: '10'))
        timeout(time: 30, unit: 'MINUTES')
    }

    stages {
        stage('Clean Workspace') {
            steps {
                script {
                    // Debug: Log pipeline start time from environment
                    echo "PIPELINE_START_TIME from env: ${env.PIPELINE_START_TIME}"
                    def stageStartTime = System.currentTimeMillis()
                    echo "=== CLEANING WORKSPACE ==="
                    echo "Ensuring fresh workspace for each build..."
                    // Clean build outputs only to preserve Gradle cache
                    sh """
                        rm -rf app/build/outputs/ || true
                        rm -rf */build || true
                        find . -name "*.lock" -delete || true
                    """
                    echo "Workspace cleaned (build outputs only)"
                    def hasGitRepo = sh(script: "if [ -d .git ]; then echo 'true'; else echo 'false'; fi", returnStdout: true).trim() == 'true'
                    def hasGradlew = sh(script: "if [ -f gradlew ]; then echo 'true'; else echo 'false'; fi", returnStdout: true).trim() == 'true'
                    def workspaceValid = false
                    if (hasGitRepo && hasGradlew) {
                        try {
                            sh "git status --porcelain >/dev/null"
                            workspaceValid = true
                        } catch (Exception ignored) {
                            workspaceValid = false
                        }
                    }
                    env.NEEDS_FRESH_CLONE = workspaceValid ? 'false' : 'true'
                    env.WORKSPACE_STATE = workspaceValid ? 'reused' : 'fresh'
                    echo "Workspace valid: ${workspaceValid}; Fresh clone required: ${env.NEEDS_FRESH_CLONE}"
                    def stageDuration = System.currentTimeMillis() - stageStartTime
                    env.CLEAN_WORKSPACE_DURATION = stageDuration.toString()
                    echo "Clean Workspace completed in ${stageDuration}ms"
                }
            }
        }

        stage('Checkout') {
            steps {
                script {
                    def stageStartTime = System.currentTimeMillis()
                    def checkoutBranch = 'ci'
                    env.EFFECTIVE_GIT_BRANCH = checkoutBranch
                    echo "=== BUILD CONFIGURATION ==="
                    echo "Docker Image: ${env.DOCKER_IMAGE_TAG}"
                    echo "Git Commit: ${env.GIT_COMMIT}"
                    echo "Git Branch (requested): ${params.GIT_BRANCH}"
                    echo "Effective checkout branch: ${checkoutBranch}"
                    echo "Repository: ${env.GIT_REPO_URL}"
                    echo "Build Number: ${env.BUILD_NUMBER}"
                    echo ""
                    echo "=== BUILD PARAMETERS ==="
                    echo "APP_NAME: ${params.APP_NAME}"
                    echo "APP_ID: ${params.APP_ID}"
                    echo "SERVER_IP: ${params.SERVER_IP}"
                    echo "APP_MODULE: ${params.APP_MODULE}"
                    echo "BUILD_TYPE: release (forced)"
                    echo "MINIO_BUCKET: ${params.MINIO_BUCKET}"
                    echo "GIT_BRANCH PARAM: ${params.GIT_BRANCH}"
                    echo ""

                    withCredentials([string(credentialsId: env.GIT_CREDENTIALS_ID, variable: 'GITHUB_TOKEN')]) {
                        boolean needsFreshClone = (env.NEEDS_FRESH_CLONE ?: 'true') != 'false'
                        String checkoutStrategy = needsFreshClone ? 'fresh-clone' : 'incremental-pull'
                        if (needsFreshClone) {
                            echo "Fresh workspace detected - cloning repository..."
                            sh """
                                set -e
                                rm -rf .git 2>/dev/null || true
                                git clone --branch ${checkoutBranch} --single-branch https://\$GITHUB_TOKEN@github.com/twsbp/tc-app-kotlin.git .
                            """
                            env.WORKSPACE_STATE = 'fresh'
                        } else {
                            echo "Existing workspace detected - attempting incremental pull..."
                            try {
                                sh """
                                    set -e
                                    git reset --hard HEAD || true
                                    git clean -fd || true
                                    git fetch origin
                                    git checkout ${checkoutBranch} || true
                                    git reset --hard origin/${checkoutBranch}
                                """
                                env.WORKSPACE_STATE = 'reused'
                            } catch (Exception pullError) {
                                echo "Incremental git update failed: ${pullError.getMessage()}"
                                echo "Falling back to fresh clone..."
                                sh """
                                    set -e
                                    rm -rf .git 2>/dev/null || true
                                    git clone --branch ${checkoutBranch} --single-branch https://\$GITHUB_TOKEN@github.com/twsbp/tc-app-kotlin.git .
                                """
                                checkoutStrategy = 'fresh-clone-fallback'
                                env.WORKSPACE_STATE = 'fresh'
                            }
                        }
                        env.CHECKOUT_STRATEGY = checkoutStrategy
                    }

                    sh "git checkout ${checkoutBranch}"
                    sh "git reset --hard origin/${checkoutBranch}"

                    // Verify workspace contents after checkout
                    sh '''
                        echo "=== WORKSPACE VERIFICATION ==="
                        echo "Workspace contents after git checkout:"
                        ls -la

                        if [ -f "./gradlew" ]; then
                            echo "gradlew found"
                        else
                            echo "gradlew not found"
                        fi

                        if [ -f "build.gradle" ] || [ -f "build.gradle.kts" ]; then
                            echo "build configuration found"
                        else
                            echo "build configuration not found"
                        fi
                    '''

                    def stageDuration = System.currentTimeMillis() - stageStartTime
                    env.CHECKOUT_DURATION = stageDuration.toString()
                    def strategyLabel = env.CHECKOUT_STRATEGY ?: 'unknown'
                    echo "Checkout completed in ${stageDuration}ms using strategy: ${strategyLabel}"
                }
            }
        }

        stage('Validate Parameters') {
            steps {
                script {
                    echo "Validating build parameters..."

                    // Validate APP_ID format (allow full package or derived TCS code)
                    def appIdIsFull = params.APP_ID ==~ /^com\.twsbp\.[a-zA-Z0-9_]+$/
                    def appIdIsTcsCode = params.APP_ID ==~ /^TCS[0-9]+$/
                    if (!appIdIsFull && !appIdIsTcsCode) {
                        error("Invalid APP_ID format: '${params.APP_ID}'. Expected format: com.twsbp.XXXX or TCS##")
                    }

                    // Validate SERVER_IP (IP address or hostname)
                    if (!params.SERVER_IP.matches(/^(\d{1,3}\.){3}\d{1,3}$|^[a-zA-Z0-9.-]+$/)) {
                        error("Invalid SERVER_IP format: '${params.SERVER_IP}'. Expected IP address or hostname")
                    }

                    // Validate APP_MODULE (alphanumeric)
                    if (!params.APP_MODULE.matches(/^[a-zA-Z0-9]+$/)) {
                        error("Invalid APP_MODULE format: '${params.APP_MODULE}'. Only alphanumeric characters allowed")
                    }

                    // Validate APP_NAME (not empty, reasonable length, supports Traditional Chinese)
                    if (params.APP_NAME.trim().isEmpty() || params.APP_NAME.length() > 50) {
                        error("APP_NAME must be non-empty and less than 50 characters")
                    }

                    // Validate COMPANY (alphanumeric, underscore, hyphen)
                    if (!params.COMPANY.matches(/^[a-zA-Z0-9_-]+$/)) {
                        error("Invalid COMPANY format: '${params.COMPANY}'. Only alphanumeric, underscore, and hyphen allowed")
                    }

                    echo "All parameters validated successfully"
                }
            }
        }

        stage('Setup Environment') {
            steps {
                script {
                    echo "=== DOCKER IMAGE VERIFICATION ==="
                    echo "Using Docker image: ${env.DOCKER_IMAGE_TAG}"

                    // Ensure the Android SDK build image is available locally (skip pull if already present)
                    if (!sh(script: "docker image inspect ${env.DOCKER_IMAGE_TAG} >/dev/null 2>&1", returnStatus: true)) {
                        sh "docker pull ${env.DOCKER_IMAGE_TAG}"
                    }
                    sh "docker image inspect ${env.DOCKER_IMAGE_TAG} --format='{{.RepoTags}} {{.Created}} {{.Id}}'"

                    // Clean up any existing container
                    sh 'docker rm -f android-builder >/dev/null 2>&1 || true'

                    // Determine the actual Jenkins home volume name so the builder container
                    // can see the checked-out workspace. Docker Compose prefixes named volumes,
                    // so we inspect the running Jenkins container to find the correct volume.
                    def jenkinsHomeVolume = sh(returnStdout: true, script: """
                        docker inspect -f '{{ range .Mounts }}{{ if eq .Destination "/var/jenkins_home" }}{{ .Name }}{{ end }}{{ end }}' jenkins-android-ci
                    """).trim()
                    if (!jenkinsHomeVolume) {
                        error "Failed to determine Jenkins home volume name from container jenkins-android-ci"
                    }

                    // Run the Android SDK container sharing the same Jenkins home volume
                    // (resolved above) so it can access the workspace files.
                    sh """
                        docker run --rm -d --name android-builder \
                            --user root \
                            -v ${jenkinsHomeVolume}:/var/jenkins_home \
                            -v gradle-cache:/root/.gradle \
                            -w ${env.WORKSPACE} \
                            -e ANDROID_HOME=/opt/android-sdk \
                            -e ANDROID_SDK_ROOT=/opt/android-sdk \
                            -e GRADLE_USER_HOME=/root/.gradle \
                            ${env.DOCKER_IMAGE_TAG} tail -f /dev/null
                    """

                    // Verify container is running and has correct workspace
                    sh """
                        echo "Container status:"
                        docker ps --filter name=android-builder

                        echo "Verifying workspace in container:"
                        docker exec android-builder pwd
                        docker exec android-builder ls -la ${env.WORKSPACE}

                        echo "Verifying file accessibility in container (via shared jenkins_home volume):"
                        docker exec android-builder sh -c 'test -f "${env.WORKSPACE}/gradlew" && echo "gradlew accessible" || echo "gradlew not accessible"'
                        docker exec android-builder sh -c 'test -f "${env.WORKSPACE}/build.gradle.kts" && echo "build.gradle.kts accessible" || echo "build.gradle.kts not accessible"'
                        docker exec android-builder sh -c 'ls -la "${env.WORKSPACE}/gradlew" && echo "gradlew permissions OK" || echo "gradlew permission issue"'
                    """

                    // Create gradle.properties if it doesn't exist
                    sh '''
                        if [ ! -f gradle.properties ]; then
                            touch gradle.properties
                            echo "Created gradle.properties file"
                        fi
                    '''

                    // Set up Gradle wrapper permissions
                    sh 'chmod +x gradlew'

                    // Verify Android tools and Gradle in the Android SDK container
                    echo "=== ANDROID BUILD ENVIRONMENT VERIFICATION ==="
                    sh '''
                        echo "Gradle version (via wrapper):"
                        docker exec android-builder ./gradlew --version

                        echo "Android SDK location:"
                        docker exec android-builder sh -c 'echo "ANDROID_HOME: $ANDROID_HOME"'

                        echo "Android SDK tools:"
                        docker exec android-builder sh -c 'ls -la $ANDROID_HOME/cmdline-tools/latest/bin/sdkmanager 2>/dev/null && echo "SDK Manager found" || echo "SDK Manager not found"'

                        echo "Java version:"
                        docker exec android-builder java -version

                        echo "Available Android components (first 10):"
                        docker exec android-builder sh -c '$ANDROID_HOME/cmdline-tools/latest/bin/sdkmanager --list 2>/dev/null | head -10 || echo "SDK manager not available"'

                        echo "User home directory:"
                        docker exec android-builder sh -c 'echo "HOME: $HOME"'

                        echo "Gradle installation (via wrapper):"
                        docker exec android-builder sh -c './gradlew --version || echo "gradle CLI not on PATH (using wrapper instead)"'
                    '''
                }
            }
        }

        stage('Build') {
            steps {
                script {
                    def stageStartTime = System.currentTimeMillis()
                    def appIdFull = params.APP_ID?.trim()
                    def appIdParts = appIdFull ? appIdFull.tokenize('.') : []
                    def appIdSuffix = appIdParts ? appIdParts.last() : ''
                    if (!appIdSuffix) {
                        error("Failed to derive APP_ID suffix from '${params.APP_ID}'. Expected format like 'com.twsbp.XXXX'")
                    }

                    def gradleCommand = "./gradlew clean assembleRelease " +
                        "-PAPP_NAME='${params.APP_NAME}' " +
                        "-PAPP_ID='${appIdSuffix}' " +
                        "-PSERVER_IP='${params.SERVER_IP}' " +
                        "-PAPP_MODULE='${params.APP_MODULE}' " +
                        "-PBUILD_NUMBER=${env.BUILD_NUMBER}"

                    echo "=== ANDROID BUILD EXECUTION ==="
                    echo "Executing Gradle build in the Android SDK container"
                    echo "Working directory: ${env.WORKSPACE}"
                    echo "APP_ID (full): ${params.APP_ID}"
                    echo "APP_ID suffix passed to Gradle: ${appIdSuffix}"
                    echo "Command: ${gradleCommand}"

                    // Verify required files exist before building
                    sh '''
                        echo "Checking for required files..."
                        if [ ! -f "./gradlew" ]; then
                            echo "ERROR: gradlew not found in workspace"
                            echo "Workspace contents:"
                            ls -la
                            exit 1
                        fi

                        if [ ! -f "build.gradle" ] && [ ! -f "build.gradle.kts" ]; then
                            echo "ERROR: build.gradle not found in workspace"
                            echo "Workspace contents:"
                            ls -la
                            exit 1
                        fi

                        echo "Required files found, proceeding with build"
                    '''

                    def gradleStartTime = System.currentTimeMillis()
                    echo "Gradle build starting at ${new Date(gradleStartTime)}"

                    // Execute build in the container with proper working directory
                    // NOTE: android-builder shares the jenkins_home volume, so
                    // ${env.WORKSPACE} inside the container has the same contents
                    // as the Jenkins workspace used for the checkout.
                    sh """
                        docker exec -w ${env.WORKSPACE} android-builder ${gradleCommand} --build-cache
                    """

                    long gradleDuration = System.currentTimeMillis() - gradleStartTime
                    env.GRADLE_DURATION = gradleDuration.toString()
                    long gradleSeconds = Math.floorDiv(gradleDuration, 1000L)
                    echo "Gradle execution time: ${gradleDuration}ms (${gradleSeconds}s)"
                    if (gradleSeconds > 900) {
                        echo "ALERT: Gradle build exceeded 15 minutes."
                    } else if (gradleSeconds > 600) {
                        echo "WARNING: Gradle build exceeded 10 minutes."
                    } else {
                        echo "Gradle build completed within acceptable time."
                    }

                    long totalDuration = System.currentTimeMillis() - stageStartTime
                    env.BUILD_DURATION = totalDuration.toString()
                    long totalSeconds = Math.floorDiv(totalDuration, 1000L)
                    long setupDuration = totalDuration - gradleDuration
                    def efficiency = totalDuration > 0 ? ((gradleDuration * 100) / totalDuration) as int : 0
                    echo "Build stage completed in ${totalDuration}ms (${totalSeconds}s)"
                    echo "Pre-Gradle setup time: ${setupDuration}ms"
                    echo "Gradle accounted for ${efficiency}% of the Build stage"
                    if (totalSeconds > 900) {
                        echo "ALERT: Build stage exceeded 15 minutes."
                    } else if (totalSeconds > 600) {
                        echo "WARNING: Build stage exceeded 10 minutes."
                    }
                }
            }
        }

        stage('Archive Artifacts') {
            steps {
                script {
                    def buildType = 'release'
                    def apkPattern = "app/build/outputs/apk/${buildType}/*.apk"


                    echo "Archiving build artifacts..."

                    // Archive APK files
                    archiveArtifacts artifacts: apkPattern, fingerprint: true



                    // Archive mapping files (if available)
                    archiveArtifacts artifacts: 'app/build/outputs/mapping/**/*.txt', allowEmptyArchive: true

                    // Archive build reports
                    archiveArtifacts artifacts: 'app/build/reports/**/*', allowEmptyArchive: true
                }
            }
        }

        stage('Upload to MinIO') {
            when {
                expression {
                    def effectiveBranch = env.EFFECTIVE_GIT_BRANCH ?: params.GIT_BRANCH
                    return effectiveBranch in ['main', 'develop', 'ci']
                }
            }
            steps {
                script {
                    echo "Uploading artifacts to MinIO..."

                    def buildType = 'release'

                    // Get app version from AppConstants.kt with robust fallback
                    def appVersion = ''
                    try {
                        appVersion = sh(returnStdout: true, script: """
                            if [ -f core/domain/src/main/java/com/starlai/core/domain/util/AppConstants.kt ]; then
                                VERSION=\$(grep -o 'var appVersion: String = "[^"]*"' core/domain/src/main/java/com/starlai/core/domain/util/AppConstants.kt | cut -d'"' -f2)
                                if [ -n "\$VERSION" ] && [ "\$VERSION" != '""' ]; then
                                    echo "\$VERSION"
                                else
                                    echo "build-${env.BUILD_NUMBER}"
                                fi
                            else
                                echo "build-${env.BUILD_NUMBER}"
                            fi
                        """).trim()
                    } catch (err) {
                        echo "Failed to extract app version: ${err.getMessage()}"
                        appVersion = "build-${env.BUILD_NUMBER}"
                    }

                    // Ensure we have a valid version
                    if (!appVersion || appVersion.trim().isEmpty()) {
                        appVersion = "build-${env.BUILD_NUMBER}"
                    }

                    echo "Using app version for MinIO path: v${appVersion}"
                    def minioPath = "${params.MINIO_BUCKET}/${params.COMPANY}/v${appVersion}"

                    // Verify MinIO connectivity before proceeding
                    sh """
                        echo "=== VERIFYING MINIO CONNECTIVITY ==="
                        echo "Testing connection to MinIO at ${env.MINIO_ENDPOINT}..."

                        # Test basic connectivity
                        for i in {1..3}; do
                            if curl -f --connect-timeout 5 --max-time 10 ${env.MINIO_ENDPOINT}/minio/health/live; then
                                echo "MinIO is reachable (attempt \$i)"
                                break
                            else
                                echo "MinIO connection attempt \$i failed, retrying..."
                                if [ \$i -eq 3 ]; then
                                    echo "Failed to connect to MinIO after 3 attempts"
                                    exit 1
                                fi
                                sleep 2
                            fi
                        done
                    """

                    // Configure MinIO client
                    sh """
                        mc alias set minio ${env.MINIO_ENDPOINT} ${env.MINIO_ACCESS_KEY} ${env.MINIO_SECRET_KEY}

                        # Verify MinIO client configuration
                        echo "Testing MinIO client configuration..."
                        mc admin info minio || echo "Admin info failed (may be permissions issue)"
                        mc ls minio/ || echo "List buckets failed (may be permissions issue)"
                    """



                    // Upload APK files (MinIO auto-creates bucket if needed)
                    sh """
                        echo "=== UPLOADING APK FILES ==="
                        find app/build/outputs/apk/${buildType} -name "*.apk" -exec echo "Uploading: {}" \\; -exec mc cp {} minio/${minioPath}/ \\;
                        echo "APK files uploaded to minio://${minioPath}/"
                    """

                    // appVersion already extracted above for MinIO path

                    // Upload build metadata
                    // Debug: Log timing values for metadata
                    echo "DEBUG: Metadata - PIPELINE_START_TIME = '${env.PIPELINE_START_TIME}'"
                    long metadataPipelineStart = 0
                    try {
                        if (env.PIPELINE_START_TIME && env.PIPELINE_START_TIME.trim()) {
                            metadataPipelineStart = env.PIPELINE_START_TIME as Long
                        } else {
                            metadataPipelineStart = System.currentTimeMillis()
                            echo "DEBUG: Using current time as fallback for metadata"
                        }
                    } catch (Exception e) {
                        echo "DEBUG: Failed to parse PIPELINE_START_TIME for metadata: ${e.getMessage()}"
                        metadataPipelineStart = System.currentTimeMillis()
                    }
                    def pipelineStart = new Date(metadataPipelineStart)
                    def metadata = [
                        build_number: env.BUILD_NUMBER,
                        git_commit: env.GIT_COMMIT,
                        git_branch: env.EFFECTIVE_GIT_BRANCH ?: env.GIT_BRANCH,
                        docker_image: env.DOCKER_IMAGE_TAG,
                        app_name: params.APP_NAME,
                        app_id: params.APP_ID,
                        app_version: appVersion,
                        server_ip: params.SERVER_IP,
                        app_module: params.APP_MODULE,
                        company: params.COMPANY,
                        minio_path: minioPath,
                        build_type: 'release',
                        checkout_strategy: env.CHECKOUT_STRATEGY ?: 'unknown',
                        workspace_state: env.WORKSPACE_STATE ?: (env.NEEDS_FRESH_CLONE == 'false' ? 'reused' : 'fresh'),
                        pipeline_start_time: pipelineStart.format("yyyy-MM-dd'T'HH:mm:ss'Z'"),
                        total_duration_ms: env.TOTAL_PIPELINE_DURATION ?: '0',
                        clean_workspace_duration_ms: env.CLEAN_WORKSPACE_DURATION ?: '0',
                        checkout_duration_ms: env.CHECKOUT_DURATION ?: '0',
                        build_duration_ms: env.BUILD_DURATION ?: '0',
                        gradle_duration_ms: env.GRADLE_DURATION ?: '0',
                        timestamp: new Date().format("yyyy-MM-dd'T'HH:mm:ss'Z'")
                    ]

                    writeJSON file: 'build-metadata.json', json: metadata
                    sh """
                        echo "=== UPLOADING BUILD METADATA ==="
                        mc cp build-metadata.json minio/${minioPath}/
                        echo "Build metadata uploaded"
                    """

                    def timingData = [
                        build_number: env.BUILD_NUMBER,
                        checkout_strategy: env.CHECKOUT_STRATEGY ?: 'unknown',
                        workspace_state: env.WORKSPACE_STATE ?: (env.NEEDS_FRESH_CLONE == 'false' ? 'reused' : 'fresh'),
                        git_branch: env.EFFECTIVE_GIT_BRANCH ?: env.GIT_BRANCH,
                        app_name: params.APP_NAME,
                        app_id: params.APP_ID,
                        app_version: appVersion,
                        company: params.COMPANY,
                        minio_path: minioPath,
                        total_duration_ms: env.TOTAL_PIPELINE_DURATION ?: '0',
                        clean_workspace_duration_ms: env.CLEAN_WORKSPACE_DURATION ?: '0',
                        checkout_duration_ms: env.CHECKOUT_DURATION ?: '0',
                        build_duration_ms: env.BUILD_DURATION ?: '0',
                        gradle_duration_ms: env.GRADLE_DURATION ?: '0',
                        timestamp: new Date().format("yyyy-MM-dd'T'HH:mm:ss'Z'")
                    ]
                    writeJSON file: 'build-timing.json', json: timingData
                    sh """
                        echo "=== UPLOADING BUILD TIMING DATA ==="
                        mc cp build-timing.json minio/${minioPath}/
                        echo "Build timing data uploaded"
                    """


                    echo "=== MINIO UPLOAD SUMMARY ==="
                    echo "Company: ${params.COMPANY}"
                    echo "Version: v${appVersion}"
                    echo "MinIO Path: minio://${minioPath}/"
                    sh "mc ls minio/${minioPath}/ || echo 'Could not list uploaded files'"
                    echo "All artifacts uploaded to MinIO: minio://${minioPath}/"
                }
            }
        }
    }

    post {
        success {
            script {
                echo "Build completed successfully!"
                echo "Build artifacts archived in Jenkins build #${env.BUILD_NUMBER}"
                def successBranch = env.EFFECTIVE_GIT_BRANCH ?: params.GIT_BRANCH
                if (successBranch in ['main', 'develop', 'ci']) {
                    echo "Artifacts uploaded to MinIO bucket: ${params.MINIO_BUCKET}"
                    
                    // Construct artifact path for the main APK file
                    // Expected format: company/v{version}/{filename}.apk
                    def mainApkPath = ''
                    try {
                        // Find the main APK file (usually the release APK)
                        def apkFiles = sh(returnStdout: true, script: """
                            find app/build/outputs/apk/release -name "*.apk" -not -name "*-unsigned.apk" -not -name "*-unaligned.apk" | head -1 || echo ''
                        """).trim()
                        
                        if (apkFiles) {
                            def apkFileName = apkFiles.split('/').last()
                            // Build path: {company}/v{version}/{filename}.apk
                            mainApkPath = "${params.COMPANY}/v${appVersion}/${apkFileName}"
                            echo "Main APK path for webhook: ${mainApkPath}"
                        } else {
                            echo "Warning: Could not find main APK file for webhook"
                        }
                    } catch (err) {
                        echo "Error constructing APK path for webhook: ${err.getMessage()}"
                    }
                    
                    // Call API webhook with artifact path
                    if (mainApkPath) {
                        try {
                            def buildId = params.BUILD_ID ?: ''
                            if (!buildId) {
                                echo "Warning: BUILD_ID parameter not set, cannot call webhook"
                                echo "Build ID should be passed from API when triggering Jenkins build"
                            } else {
                                echo "Calling webhook for build ${buildId} with artifact path: ${mainApkPath}"
                                
                                def webhookPayload = """
                                {
                                    "status": "completed",
                                    "stage": "Upload to MinIO",
                                    "progress": 100,
                                    "artifactPath": "${mainApkPath}",
                                    "startTime": ${env.PIPELINE_START_TIME ?: 'null'},
                                    "endTime": ${System.currentTimeMillis()},
                                    "metrics": {
                                        "jenkinsBuildNumber": ${env.BUILD_NUMBER},
                                        "gitCommit": "${env.GIT_COMMIT ?: ''}",
                                        "gitBranch": "${env.EFFECTIVE_GIT_BRANCH ?: params.GIT_BRANCH}"
                                    }
                                }
                                """.trim()
                                
                                sh """
                                    echo "Sending webhook payload: ${webhookPayload}"
                                    curl -X POST "${env.API_ENDPOINT}/builds/${buildId}/webhook" \\
                                        -H "Content-Type: application/json" \\
                                        -d '${webhookPayload}' \\
                                        --connect-timeout 30 \\
                                        --max-time 60 \\
                                        --retry 3 \\
                                        --retry-delay 5 || echo "Webhook call failed"
                                """
                            }
                        } catch (err) {
                            echo "Error calling webhook: ${err.getMessage()}"
                            echo "Build artifacts were uploaded to MinIO but API was not notified"
                        }
                    }
                }
            }
        }

        failure {
            script {
                echo "Build failed!"
                echo "Check the build log above for error details."

                 // No email notifications configured
            }
        }

        unstable {
            script {
                echo "Build completed with test failures!"
            }
        }

        always {
            script {
                def pipelineEndTime = System.currentTimeMillis()
                // Debug: Log timing values for troubleshooting
                echo "DEBUG: PIPELINE_START_TIME = '${env.PIPELINE_START_TIME}'"
                echo "DEBUG: pipelineEndTime = ${pipelineEndTime}"

                // More robust parsing with fallback
                long pipelineStart = 0
                try {
                    if (env.PIPELINE_START_TIME && env.PIPELINE_START_TIME.trim()) {
                        pipelineStart = env.PIPELINE_START_TIME as Long
                        echo "DEBUG: Successfully parsed PIPELINE_START_TIME as ${pipelineStart}"
                    } else {
                        echo "DEBUG: PIPELINE_START_TIME is empty or null, using fallback"
                        pipelineStart = pipelineEndTime
                    }
                } catch (Exception e) {
                    echo "DEBUG: Failed to parse PIPELINE_START_TIME: ${e.getMessage()}"
                    pipelineStart = pipelineEndTime
                }

                long totalDuration = pipelineEndTime - pipelineStart
                env.TOTAL_PIPELINE_DURATION = totalDuration.toString()
                long totalDurationSeconds = Math.floorDiv(totalDuration, 1000L)
                echo "=== PIPELINE SUMMARY ==="
                echo "Total pipeline duration: ${totalDuration}ms (${totalDurationSeconds}s)"
                echo "Clean Workspace duration: ${env.CLEAN_WORKSPACE_DURATION ?: 'n/a'}ms"
                echo "Checkout duration: ${env.CHECKOUT_DURATION ?: 'n/a'}ms"
                echo "Build duration: ${env.BUILD_DURATION ?: 'n/a'}ms"
                echo "Gradle duration: ${env.GRADLE_DURATION ?: 'n/a'}ms"
                echo "Checkout strategy used: ${env.CHECKOUT_STRATEGY ?: 'unknown'}"

                def cleanupLabel = env.NODE_NAME ?: 'built-in'
                node(cleanupLabel) {
                    // Clean up Android builder container
                    sh 'docker stop android-builder || true'
                    sh 'docker rm android-builder || true'

                    // Clean up workspace
                    cleanWs()

                    echo "Pipeline completed at: ${new Date(pipelineEndTime)}"
                }
            }
        }
    }
}
